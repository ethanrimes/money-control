# ============================================================================
# MoneyControl environment template. Copy to .env (gitignored) and fill in.
# In production these are set in the Vercel dashboard (Production + Preview).
# ============================================================================

# ----- Local dev server (apps/server) ---------------------------------------
SERVER_PORT=3001

# ----- Supabase Postgres + Auth ---------------------------------------------
# Project URL + anon (publishable) key are safe to expose to the browser.
# Get them from: Supabase dashboard -> Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx

# Service-role key bypasses RLS. Server-side ONLY — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Pooled connection string (PgBouncer transaction mode, port 6543) for the app.
# Use the "Transaction pooler" string from the Supabase dashboard.
# IMPORTANT: append ?pgbouncer=true&connection_limit=1 for serverless safety.
DATABASE_URL=postgresql://postgres.your-project-ref:YOUR-PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# Direct (non-pooled, port 5432) connection — used by drizzle-kit migrations
# and one-shot scripts. NOT used by the running app.
DIRECT_URL=postgresql://postgres:YOUR-PASSWORD@db.your-project-ref.supabase.co:5432/postgres

# ----- Teller --------------------------------------------------------------
# Sandbox = demo banks; development / production = real banks (paid plan).
TELLER_ENV=sandbox
TELLER_APP_ID=
# Verifies HMAC signatures Teller attaches to Connect callbacks + webhooks.
TELLER_SIGNING_KEY=

# mTLS cert + private key. Two ways to provide them:
#   (1) Local dev: drop certificate.pem and private_key.pem into ./teller/
#       (gitignored). Leave the B64 vars below empty.
#   (2) Vercel: base64-encode each file and paste below. On cold start the
#       server writes them to /tmp and points the Teller client there.
# Generate (PowerShell):
#   [Convert]::ToBase64String([IO.File]::ReadAllBytes("teller/certificate.pem"))
#   [Convert]::ToBase64String([IO.File]::ReadAllBytes("teller/private_key.pem"))
TELLER_CERT_B64=
TELLER_KEY_B64=

# ----- Plaid ---------------------------------------------------------------
# Broader bank/brokerage coverage (Amex deposits + Fidelity investments that
# Teller doesn't cover). client_id is shared across envs; each env has its
# own secret. PLAID_ENV chooses which secret + base URL the server uses.
PLAID_ENV=sandbox
PLAID_CLIENT_ID=
PLAID_SANDBOX_SECRET=
PLAID_PRODUCTION_SECRET=
