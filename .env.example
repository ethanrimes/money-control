# Server
SERVER_PORT=3001
DATABASE_URL=file:./data/moneycontrol.db

# Teller — required to enable the "Link account" button in the web UI.
# 1. Sign up at https://teller.io and copy your Application ID.
# 2. Set TELLER_APP_ID below.
# 3. Drop the certificate.pem + private_key.pem you downloaded into ./teller/
#    (gitignored). The server reads them on startup for mTLS calls.
# Sandbox lets you link demo banks; switch to "development" or "production"
# once you've upgraded your Teller plan.
TELLER_ENV=sandbox
TELLER_APP_ID=

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001
