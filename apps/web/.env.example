# =============================================================================
# MoneyControl web (Next.js) — environment template.
#
# For local dev, copy to apps/web/.env.local and adjust as needed. Vercel reads
# the same names from the Project Settings → Environment Variables UI.
# =============================================================================

# ----- Supabase (public, embedded in the browser bundle) ---------------------
# The anon key is publishable; RLS in supabase/migrations/0001_init.sql is what
# enforces multi-tenant isolation. Matches apps/mobile/.env.example.
NEXT_PUBLIC_SUPABASE_URL=https://nkuuorwahqxugupiurub.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_NKTRoIlZmAKZ5BS0ge8FZA_F5_sccWD

# ----- Canonical site URL (used for auth redirects) --------------------------
# Required in production so signup confirmation emails point at the deployed
# app instead of whatever host happened to serve the request (which for a
# Vercel preview can be a *.vercel.app preview URL, and locally would be
# http://localhost:3000 — neither is reachable from the user's email client).
#
# Set this to the user-facing canonical URL. For preview/dev you can leave it
# unset and the code falls back to window.location.origin.
NEXT_PUBLIC_SITE_URL=https://money-control-web.vercel.app
