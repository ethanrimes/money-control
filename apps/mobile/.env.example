# =============================================================================
# MoneyControl iOS (Flutter) — environment template.
#
# The Flutter app reads these via --dart-define-from-file at build time:
#     flutter build ios --dart-define-from-file=.env
#
# For local dev, copy this file to apps/mobile/.env (gitignored) and fill in.
# CI does not read this file — it passes --dart-define directly from the
# GitHub Actions secrets / variables listed below.
# =============================================================================

# ----- Supabase (publishable, embedded in the binary) ------------------------
# These match the web app's NEXT_PUBLIC_* values from the root .env. The anon
# key is *intended* to be public; RLS in supabase/migrations/0001_init.sql is
# what keeps multi-tenant data isolated.
SUPABASE_URL=https://nkuuorwahqxugupiurub.supabase.co
SUPABASE_ANON_KEY=sb_publishable_NKTRoIlZmAKZ5BS0ge8FZA_F5_sccWD

# Deep-link scheme registered in ios/Runner/Info.plist for password-recovery
# and email-confirmation redirects. Must match what's added under
# "URL Schemes" in Supabase auth settings.
APP_DEEP_LINK_SCHEME=moneycontrol


# =============================================================================
# Inventory of GitHub Actions secrets/variables used by .github/workflows/ios.yml
# (repo: ethanrimes/money-control, environment: production).
#
# DO NOT put real values here — this file is committed. It exists so a future
# reader can see at-a-glance what CI needs. The actual values live encrypted
# in GitHub.
# =============================================================================
#
# Secrets (encrypted, never echoed in workflow logs):
#   APPSTORE_API_KEY_ID                # App Store Connect API key id (10 char alnum)
#   APPSTORE_API_ISSUER_ID             # App Store Connect issuer id (uuid)
#   APPSTORE_API_PRIVATE_KEY           # Full PEM content of AuthKey_*.p8
#   BUILD_CERTIFICATE_BASE64           # base64 of the distribution .p12
#   BUILD_PROVISION_PROFILE_BASE64     # base64 of the .mobileprovision
#   P12_PASSWORD                       # Password used when exporting the .p12
#   KEYCHAIN_PASSWORD                  # Password the workflow uses to lock the temp keychain
#
# Variables (plaintext):
#   APPLE_TEAM_ID                      # XKXCB8B22L
#   IOS_BUNDLE_ID                      # com.ethankallett.moneycontrol
#
# Rotation guidance:
#   - The .p12 / .mobileprovision pair expires yearly. Re-export from
#     developer.apple.com, base64-encode, paste in. (PowerShell:
#     [Convert]::ToBase64String([IO.File]::ReadAllBytes("cert.p12")))
#   - APPSTORE_API_PRIVATE_KEY does NOT expire — only revoke if leaked.
# =============================================================================
